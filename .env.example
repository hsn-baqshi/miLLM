# Copy to .env and adjust. Master key must start with sk- (LiteLLM requirement).
# Open WebUI uses this same value as OPENAI_API_KEY to reach LiteLLM (see docker-compose.yml).
LITELLM_MASTER_KEY=sk-change-me-to-a-long-random-secret

# Postgres (used by LiteLLM for virtual keys, teams, UI at http://localhost:4000/ui)
POSTGRES_USER=litellm
POSTGRES_PASSWORD=litellm
POSTGRES_DB=litellm

# Open WebUI (set a strong value before exposing to a network)
WEBUI_SECRET_KEY=change-me-to-a-long-random-secret

# --- Optional: Outlook MCP (docker service outlook-mcp) / Microsoft Graph ---
# Register a public-client app in Entra ID with delegated Mail.Read, Mail.Send, User.Read
# (see integrations/outlook_mcp/README.md). Work/school: tenant GUID. Personal Outlook/Hotmail: consumers
# if the app allows personal Microsoft accounts.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
# Optional: sovereign / national cloud (defaults are worldwide commercial).
# AZURE_LOGIN_HOST=login.microsoftonline.us
# GRAPH_API_ROOT=https://graph.microsoft.us/v1.0
# Optional override; space-separated Graph scopes.
# GRAPH_SCOPES=https://graph.microsoft.com/Mail.Read https://graph.microsoft.com/Mail.Send https://graph.microsoft.com/User.Read

# MCP listens inside the compose network on this port (default 8010). Open WebUI URL: http://outlook-mcp:8010/mcp
# OUTLOOK_MCP_HTTP_PORT=8010

# Host-side LiteLLM URL if you call LiteLLM from scripts on your machine (not used by outlook-mcp).
LITELLM_BASE_URL=http://127.0.0.1:4000
LITELLM_API_KEY=
LITELLM_MODEL=llama3.2
